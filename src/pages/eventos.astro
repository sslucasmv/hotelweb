
---
import BaseLayout from '../layouts/BaseLayout.astro';
import recitalesData from '../data/recitales-2026.json';
import deportesData from '../data/deportes.json';
import festivalesData from '../data/festivales.json';


const destacadosRecitales = recitalesData.slice(0, 4);
const destacadosDeportes = deportesData.slice(0, 4);
const destacadosFestivales = festivalesData.slice(0, 4);
---

<BaseLayout>

<section class="max-w-7xl mx-auto px-4 py-6">
     <div class="mb-12 border-b pb-6 border-slate-300">
            <h2 class="text-3xl font-bold text-blue-ocean tracking-tight mb-4">
                Eventos en Marzo 2026
            </h2>
          <p class="text-slate-600 text-lg">
                Consulte los diferentes eventos y festividades en nuestra ciudad.
            </p>
          
        </div>
  <div class="mb-16">
    <div class="flex justify-between items-end mb-6">
      <h2 class="text-2xl font-bold border-l-4 border-sky-600 pl-4 text-slate-800">Recitales y Música</h2>
      <a href="/eventos/recitales-2026" class="text-sky-600 font-semibold hover:text-sky-800 transition">Ver cartelera completa →</a>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {destacadosRecitales.map((evento) => (
        <div class="group bg-white border border-slate-200 rounded-2xl p-5 hover:border-sky-300 hover:shadow-xl hover:shadow-sky-500/10 transition-all duration-300">
          <span class="inline-block px-2 py-1 bg-sky-50 text-sky-600 rounded-md text-xs font-bold mb-3">
            {evento.fecha}
          </span>
          <h3 class="font-bold text-slate-800 group-hover:text-sky-600 transition-colors leading-snug">
            {evento.titulo}
          </h3>
          <p class="text-slate-500 text-sm mt-3 flex items-center gap-1">
            <span class="opacity-70">{evento.lugar}</span>
          </p>
        </div>
      ))}
    </div>
  </div>

  <div class="mb-16">
    <div class="flex justify-between items-end mb-6">
      <h2 class="text-2xl font-bold border-l-4 border-orange-500 pl-4 text-slate-800">Deportes y Maratones</h2>
      <a href="/eventos/deportes" class="text-orange-500 font-semibold hover:text-orange-700 transition">Ver agenda deportiva →</a>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {destacadosDeportes.map((evento) => (
        <div class="group bg-white border border-slate-200 rounded-2xl p-5 hover:border-orange-300 hover:shadow-xl hover:shadow-orange-500/10 transition-all duration-300">
          <span class="inline-block px-2 py-1 bg-orange-50 text-orange-600 rounded-md text-xs font-bold mb-3">
            {evento.fecha}
          </span>
          <h3 class="font-bold text-slate-800 group-hover:text-orange-600 transition-colors leading-snug">
            {evento.titulo}
          </h3>
          <p class="text-slate-500 text-sm mt-3">
            <span class="opacity-70">{evento.lugar}</span>
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
</BaseLayout>